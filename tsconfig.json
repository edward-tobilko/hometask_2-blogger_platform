{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": "src",
    "types": ["jest", "node", "reflect-metadata", "pino"],

    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "inlineSources": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // * for inversify / reflect-metadata
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "baseUrl": "src",

    "paths": {
      // * для удобного импорта файлов
      "@core/*": ["core/*"],
      "@tests/*": ["__tests__/*"],
      "composition-root": ["composition-root.ts"],
      "@users/*": ["users/*"],
      "@security-devices/*": ["security-devices/*"],
      "@posts/*": ["posts/*"],
      "@comments/*": ["comments/*"],
      "@blogs/*": ["blogs/*"],
      "@auth/*": ["auth/*"]
    }
  },

  "files": ["src/types/express.d.ts"],

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
